# Code Helper — environment variables
# Copy to .env and adjust. See docs/CONFIG.md for full contract.
# All of these are optional; defaults are shown.

# ---- Crew API ----
# Runner service base URL (used for /run and readiness)
RUNNER_URL=http://runner:8080
# Alternative: RUNNER_SERVICE_URL (used if RUNNER_URL unset)

# Chroma base URL. Empty = in-memory for ingest; readiness treats empty as not_configured
VECTOR_DB_URL=http://chroma:8000

# LLM base URL (Ollama or vLLM). Used for readiness and crew.
LLM_URL=
# Alternative: OPENAI_BASE_URL (CrewAI convention)

# Path for LLM health check (e.g. /health for vLLM; default / for Ollama)
# LLM_HEALTH_PATH=

# Kubernetes namespace for ingest Job creation
K8S_NAMESPACE=code-helper

# Docker image for the ingest Job
INGEST_IMAGE=code-helper-ingest

# Set to 1, true, or yes to validate Runner and Chroma at startup (fail fast if unreachable)
CREW_API_VALIDATE_DEPS=0

# ---- Runner ----
# Root directory under which project_path must lie for POST /execute
ALLOWED_ROOT=/workspace

# ---- Ingest (when run as K8s Job or standalone) ----
# Chroma URL (or set VECTOR_DB_URL; CHROMA_URL used if VECTOR_DB_URL unset)
# VECTOR_DB_URL=...
# CHROMA_URL=...
